/* ── 日平线页面专用样式 ── */

.lock-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.lock-row .input-field {
  flex: 1;
}

.lock-btn {
  width: 72rpx;
  height: 72rpx;
  min-width: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 14rpx;
  border: 1rpx solid rgba(21, 47, 82, 0.12);
  background: linear-gradient(180deg, #f8fbff 0%, #eff4fb 100%);
  font-size: 30rpx;
  padding: 0;
  margin: 0;
  flex-shrink: 0;
  color: #5b7088;
  transition: all 0.2s ease;
}

.lock-btn::after {
  border: none;
}

.lock-btn.locked {
  background: linear-gradient(180deg, #fff5f5 0%, #ffeef0 100%);
  border-color: rgba(199, 0, 11, 0.16);
  color: #b31a22;
}

.input-field.disabled {
  background: linear-gradient(180deg, #f5f7fa 0%, #eef1f6 100%);
  color: #9aa7b5;
}

/* 节点卡片 */
.cp-card {
  border-radius: 18rpx;
  border: 1rpx solid rgba(21, 47, 82, 0.08);
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
  padding: 20rpx;
}

.cp-card.is-month-end {
  grid-column: 1 / -1;
  border-color: rgba(199, 0, 11, 0.12);
  background: linear-gradient(180deg, #fff8f8 0%, #fff1f1 100%);
}

.cp-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.cp-date {
  font-size: 24rpx;
  font-weight: 650;
  color: #10253d;
}

.cp-weight {
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(21, 47, 82, 0.06);
  color: #5b7088;
}

.cp-card.is-month-end .cp-weight {
  background: rgba(199, 0, 11, 0.08);
  color: #b31a22;
}

.cp-hint {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #728399;
  line-height: 1.4;
}

.cp-hint.need-hint {
  color: #b31a22;
  font-weight: 600;
}

/* 结果面板 */
.line-result-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.line-metric {
  border-radius: 18rpx;
  border: 1rpx solid rgba(21, 47, 82, 0.08);
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  padding: 20rpx;
}

.line-metric.primary {
  background: linear-gradient(180deg, #fff8f8 0%, #fff1f1 100%);
  border-color: rgba(199, 0, 11, 0.12);
}

.line-metric .metric-value {
  font-size: 36rpx;
}

.line-metric.primary .metric-value {
  font-size: 42rpx;
  color: #bb131d;
}

/* 倒推区域 */
.reverse-section {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #f0f5fb 100%);
  border: 1rpx solid rgba(21, 47, 82, 0.08);
}

.reverse-section .field-label {
  margin-bottom: 8rpx;
}
